# Wildpath Adventures — local development environment
# Production values are set in the Vercel project dashboard.

NEXT_PUBLIC_SITE_DOMAIN=wildpathnamibia.com
NEXT_PUBLIC_SITE_URL=https://wildpathnamibia.com
NEXT_PUBLIC_CONTACT_EMAIL=journeys@wildpathnamibia.com
CONTACT_RECIPIENT=journeys@wildpathnamibia.com
NEXT_PUBLIC_PHONE_DISPLAY=+264 81 255 7741
NEXT_PUBLIC_PHONE_E164=264812557741

# Until SMTP is configured, enquiries are stored to a local JSON file
# for the ops team to retrieve. Set SMTP_URL to enable real email delivery.
ENQUIRY_STORE_PATH=/home/z/my-project/data/enquiries.json

DATABASE_URL=file:/home/z/my-project/db/custom.db
